{
	"name": "start-elysia-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"check-types": "turbo run check-types",
		"db:up": "docker compose up postgres -d",
		"db:down": "docker compose stop postgres",
		"db:status": "docker compose ps",
		"compose:up": "docker compose up -d",
		"compose:down": "docker compose down",
		"test": "turbo run test",
		"test:e2e": "turbo run test:e2e",
		"test:ui": "turbo run test:ui",
		"docker:build:api": "docker build -t start-elysia-api -f apps/api/Dockerfile .",
		"docker:build:web": "docker build -t start-elysia-web -f apps/web/Dockerfile .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@repo/biome-config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"rimraf": "^6.1.3",
		"turbo": "^2.8.14",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched"
	}
}
