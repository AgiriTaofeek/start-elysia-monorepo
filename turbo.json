{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": [
		"SKIP_ENV_VALIDATION",
		"DATABASE_URL",
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["SKIP_ENV_VALIDATION"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"env": ["SKIP_ENV_VALIDATION"]
		},
		"format": {
			"env": ["SKIP_ENV_VALIDATION"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"]
		},
		"test:e2e": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"]
		},
		"test:ui": {
			"cache": false,
			"persistent": true
		}
	}
}
