# Stage 1: Pruner
FROM oven/bun:alpine AS pruner
WORKDIR /app
RUN apk add --no-cache nodejs
RUN bun add -g turbo
COPY . .
RUN turbo prune @repo/web --docker

# Stage 2: Installer
FROM oven/bun:alpine AS installer
WORKDIR /app

# Copy pruned locks and package.json
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/bun.lock ./bun.lock
RUN bun install --frozen-lockfile

# Stage 3: Builder
FROM oven/bun:alpine AS builder
WORKDIR /app
COPY --from=installer /app/ .
COPY --from=pruner /app/out/full/ .

# Build the web app
ENV SKIP_ENV_VALIDATION=1
RUN cd apps/web && bun run build

# Stage 4: Runner
FROM oven/bun:alpine AS runner
WORKDIR /app

# Create a non-root user
RUN addgroup -g 1001 -S bunuser && adduser -u 1001 -S bunuser -G bunuser
USER bunuser

# Copy built server output and public files
COPY --from=builder /app/apps/web/.output .

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# Run the Nitro server generated by TanStack Start
CMD ["bun", "run", "server/index.mjs"]
