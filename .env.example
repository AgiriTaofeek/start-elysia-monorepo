# ─── Database ─────────────────────────────────────────────────────────────────
# Matches the Docker Compose defaults in docker-compose.yml
DATABASE_URL="postgresql://postgres:password@localhost:5432/start_elysia_db?schema=public"

# ─── Auth (Better Auth) ──────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
BETTER_AUTH_URL="http://localhost:4000"

# ─── API (apps/api) ───────────────────────────────────────────────────────────
PORT=4000

# ─── Web (apps/web) ───────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
VITE_BETTER_AUTH_URL="http://localhost:4000"